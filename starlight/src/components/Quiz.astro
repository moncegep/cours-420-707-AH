---
// src/components/Quiz.astro
// Quiz à choix unique, autonome. Le style est scopé et le script est groupé
// par Astro (un seul écouteur délégué, quel que soit le nombre de quiz).
interface Option {
  text: string;
  correct: boolean;
}
interface Props {
  question: string;
  options: Option[];
  feedback?: string;
}
const { question, options, feedback } = Astro.props;
---

<div class="quiz" data-quiz>
  <p class="quiz-q"><strong>Quiz.</strong> {question}</p>
  {
    options.map((opt) => (
      <button class="quiz-opt" data-correct={opt.correct ? "true" : "false"}>
        {opt.text}
      </button>
    ))
  }
  {feedback && <p class="quiz-feedback" hidden>{feedback}</p>}
</div>

<style>
  .quiz {
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.5rem;
    padding: 1rem 1.25rem;
    margin: 1.5rem 0;
    background: var(--sl-color-gray-6);
  }
  .quiz-q {
    margin-top: 0;
  }
  .quiz-opt {
    display: block;
    width: 100%;
    text-align: left;
    margin: 0.4rem 0;
    padding: 0.5rem 0.75rem;
    border: 1px solid var(--sl-color-gray-4);
    border-radius: 0.375rem;
    background: var(--sl-color-bg);
    color: var(--sl-color-text);
    cursor: pointer;
    font: inherit;
  }
  .quiz-opt:hover:not(:disabled) {
    border-color: var(--sl-color-accent);
  }
  .quiz-opt:disabled {
    cursor: not-allowed;
    opacity: 0.6;
  }
  .quiz-opt.is-correct {
    border-color: #22c55e;
    background: color-mix(in srgb, #22c55e 15%, transparent);
    font-weight: 700;
  }
  .quiz-opt.is-wrong {
    border-color: #ef4444;
    background: color-mix(in srgb, #ef4444 12%, transparent);
  }
  .quiz-feedback {
    margin-bottom: 0;
    padding: 0.5rem 0.75rem;
    border-radius: 0.375rem;
    background: color-mix(in srgb, #22c55e 12%, transparent);
  }
</style>

<script>
  document.addEventListener("click", (event) => {
    const opt = event.target.closest(".quiz-opt");
    if (!opt) return;
    const quiz = opt.closest("[data-quiz]");
    if (!quiz || quiz.dataset.done === "true") return;

    if (opt.dataset.correct === "true") {
      opt.classList.add("is-correct");
      quiz.dataset.done = "true";
      const feedback = quiz.querySelector(".quiz-feedback");
      if (feedback) feedback.hidden = false;
    } else {
      opt.classList.add("is-wrong");
      opt.disabled = true;
    }
  });
</script>